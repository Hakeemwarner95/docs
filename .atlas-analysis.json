  "keyFeatures": [
    "Four analysis modes: off-grid, rural residential, recreational, and investment",
    "Async report generation with webhook delivery and polling support",
    "Structured scores with per-category confidence ratings",
    "Data citations from NREL, USGS, FEMA, and county regulation sources",
    "Downloadable PDF report with signed URL",
    "Batch analysis of up to 50 properties per request",
    "State-level land profiles for all four modes",
    "MCP server integration for AI agents (mcp.landscout.io)",
    "HMAC-SHA256 signed webhook payloads",
    "Idempotency-Key support for safe retries"
  ],
  "publicApiSurface": [
    "POST /v1/analyze",
    "GET /v1/reports/{id}",
    "GET /v1/reports/{id}/pdf",
    "POST /v1/batch",
    "GET /v1/states/{code}",
    "GET /v1/usage",
    "GET /v1/health",
